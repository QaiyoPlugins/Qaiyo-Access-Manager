msgstr "Archivo inválido. Selecciona un archivo .json exportado desde Qaiyo Access Manager."

msgid "This will overwrite all current access rules. Continue?"
msgstr "Esto sobrescribirá todas las reglas de acceso actuales. ¿Continuar?"

msgid "No import data received."
msgstr "No se recibieron datos de importación."

msgid "Invalid import file. Please use a file exported from Qaiyo Access Manager."
msgstr "Archivo de importación inválido. Usa un archivo exportado desde Qaiyo Access Manager."

msgid "Settings imported successfully!"
msgstr "¡Ajustes importados con éxito!"

msgid "Uninstall behavior"
msgstr "Comportamiento de desinstalación"

msgid "Choose what happens when you delete this plugin from the Plugins page."
msgstr "Elige qué sucede cuando eliminas este plugin desde la página de Plugins."

msgid "Delete all access rules and settings from the database when the plugin is deleted"
msgstr "Eliminar todas las reglas de acceso y ajustes de la base de datos al eliminar el plugin"

msgid "If unchecked (default), your rules are preserved so they are restored if you reinstall the plugin."
msgstr "Si no está marcado (predeterminado), tus reglas se conservan y se restauran si reinstalas el plugin."
