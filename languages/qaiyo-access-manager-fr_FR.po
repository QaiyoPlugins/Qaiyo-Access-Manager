msgstr "Exportation terminée !"

msgid "Importing..."
msgstr "Importation..."

msgid "Settings imported successfully! Reloading..."
msgstr "Paramètres importés avec succès ! Rechargement..."

msgid "Import failed."
msgstr "L'importation a échoué."

msgid "Invalid file. Please select a .json file exported from Qaiyo Access Manager."
msgstr "Fichier invalide. Veuillez sélectionner un fichier .json exporté depuis Qaiyo Access Manager."

msgid "This will overwrite all current access rules. Continue?"
msgstr "Cela écrasera toutes les règles d'accès actuelles. Continuer ?"

msgid "No import data received."
msgstr "Aucune donnée d'importation reçue."

msgid "Invalid import file. Please use a file exported from Qaiyo Access Manager."
msgstr "Fichier d'importation invalide. Veuillez utiliser un fichier exporté depuis Qaiyo Access Manager."

msgid "Settings imported successfully!"
msgstr "Paramètres importés avec succès !"

msgid "Uninstall behavior"
msgstr "Comportement de désinstallation"

msgid "Choose what happens when you delete this plugin from the Plugins page."
msgstr "Choisissez ce qui se passe lorsque vous supprimez cette extension depuis la page Extensions."

msgid "Delete all access rules and settings from the database when the plugin is deleted"
msgstr "Supprimer toutes les règles d'accès et paramètres de la base de données lors de la suppression de l'extension"

msgid "If unchecked (default), your rules are preserved so they are restored if you reinstall the plugin."
msgstr "Si non coché (par défaut), vos règles sont conservées et restaurées en cas de réinstallation."
