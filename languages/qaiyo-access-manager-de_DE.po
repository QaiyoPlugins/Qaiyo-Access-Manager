msgstr "Einstellungen erfolgreich importiert! Wird neu geladen..."

msgid "Import failed."
msgstr "Import fehlgeschlagen."

msgid "Invalid file. Please select a .json file exported from Qaiyo Access Manager."
msgstr "Ungültige Datei. Bitte wählen Sie eine von Qaiyo Access Manager exportierte .json-Datei."

msgid "This will overwrite all current access rules. Continue?"
msgstr "Dies überschreibt alle aktuellen Zugriffsregeln. Fortfahren?"

msgid "No import data received."
msgstr "Keine Importdaten empfangen."

msgid "Invalid import file. Please use a file exported from Qaiyo Access Manager."
msgstr "Ungültige Importdatei. Bitte verwenden Sie eine von Qaiyo Access Manager exportierte Datei."

msgid "Settings imported successfully!"
msgstr "Einstellungen erfolgreich importiert!"

msgid "Uninstall behavior"
msgstr "Deinstallationsverhalten"

msgid "Choose what happens when you delete this plugin from the Plugins page."
msgstr "Wählen Sie, was passiert, wenn Sie dieses Plugin von der Plugins-Seite löschen."

msgid "Delete all access rules and settings from the database when the plugin is deleted"
msgstr "Alle Zugriffsregeln und Einstellungen aus der Datenbank löschen, wenn das Plugin gelöscht wird"

msgid "If unchecked (default), your rules are preserved so they are restored if you reinstall the plugin."
msgstr "Wenn nicht aktiviert (Standard), bleiben Ihre Regeln erhalten und werden bei einer Neuinstallation wiederhergestellt."
