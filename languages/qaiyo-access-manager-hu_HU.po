msgstr "Nyitott (nincs korlátozás)"

msgid "Export Settings"
msgstr "Beállítások exportálása"

msgid "Download all access rules as a JSON file. Use this to create a backup or transfer settings to another site."
msgstr "Töltsd le az összes hozzáférési szabályt JSON fájlként. Használd mentéshez vagy másik oldalra való átvitelhez."

msgid "Export to JSON"
msgstr "Exportálás JSON-ba"

msgid "Import Settings"
msgstr "Beállítások importálása"

msgid "Upload a previously exported JSON file to restore or apply access rules. This will overwrite current settings."
msgstr "Tölts fel egy korábban exportált JSON fájlt a hozzáférési szabályok visszaállításához. Ez felülírja a jelenlegi beállításokat."

msgid "Choose file or drag & drop"
msgstr "Válassz fájlt vagy húzd ide"

msgid "Import"
msgstr "Importálás"

msgid "Exporting..."
msgstr "Exportálás..."

msgid "Export complete!"
msgstr "Exportálás kész!"

msgid "Importing..."
msgstr "Importálás..."

msgid "Settings imported successfully! Reloading..."
msgstr "Beállítások sikeresen importálva! Újratöltés..."

msgid "Import failed."
msgstr "Az importálás sikertelen."

msgid "Invalid file. Please select a .json file exported from Qaiyo Access Manager."
msgstr "Érvénytelen fájl. Kérjük, válassz egy Qaiyo Access Manager által exportált .json fájlt."

msgid "This will overwrite all current access rules. Continue?"
msgstr "Ez felülírja az összes jelenlegi hozzáférési szabályt. Folytatod?"

msgid "No import data received."
msgstr "Nem érkezett importálandó adat."

msgid "Invalid import file. Please use a file exported from Qaiyo Access Manager."
msgstr "Érvénytelen importfájl. Kérjük, használj egy Qaiyo Access Manager által exportált fájlt."

msgid "Settings imported successfully!"
msgstr "Beállítások sikeresen importálva!"

msgid "Uninstall behavior"
msgstr "Eltávolítási viselkedés"

msgid "Choose what happens when you delete this plugin from the Plugins page."
msgstr "Válaszd ki, mi történjen, amikor törlöd a plugint a Bővítmények oldalról."

msgid "Delete all access rules and settings from the database when the plugin is deleted"
msgstr "Összes hozzáférési szabály és beállítás törlése az adatbázisból a plugin törlésekor"

msgid "If unchecked (default), your rules are preserved so they are restored if you reinstall the plugin."
msgstr "Ha nincs bejelölve (alapértelmezett), a szabályok megmaradnak az adatbázisban, és újratelepítéskor visszaállnak."
